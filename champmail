#!/usr/bin/env bash
# ChampMail CLI — global entry point.
#
# Install globally for use from any terminal:
#   sudo ln -sf "$(pwd)/champmail" /usr/local/bin/champmail
#   # or add repo root to PATH in ~/.bashrc / ~/.zshrc:
#   export PATH="$HOME/Desktop/ChampMail-main-1:$PATH"
#
# Usage from anywhere:
#   champmail chat               # conversational AI interface
#   champmail setup smtp         # configure SMTP
#   champmail outreach start me@company.com
#   champmail health check

set -e

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
BACKEND="$SCRIPT_DIR/backend"

export PYTHONPATH="$BACKEND${PYTHONPATH:+:$PYTHONPATH}"

# Load .env from repo root first (lowest priority), then backend/.env
if [ -f "$SCRIPT_DIR/.env" ]; then
  set -a; source "$SCRIPT_DIR/.env" 2>/dev/null || true; set +a
fi
if [ -f "$BACKEND/.env" ]; then
  set -a; source "$BACKEND/.env" 2>/dev/null || true; set +a
fi

# Use python3 explicitly; fall back to python
PYTHON=$(command -v python3 2>/dev/null || command -v python)

exec "$PYTHON" -m cli.champmail_cli "$@"
