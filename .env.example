# ChampMail Environment Configuration
# Copy to .env and fill in your values
# All AI services route through OpenRouter - one API key for everything

# APPLICATION
DEBUG=true
ENVIRONMENT=development

# POSTGRESQL
POSTGRES_HOST=localhost
POSTGRES_USER=champmail
POSTGRES_PASSWORD=champmail_dev
POSTGRES_DB=champmail
POSTGRES_PORT=5432

# REDIS
REDIS_HOST=localhost
REDIS_PORT=6380

# CHAMPGRAPH (Knowledge Graph)
CHAMPGRAPH_URL=http://localhost:8080
CHAMPGRAPH_API_KEY=

# SECURITY (CHANGE IN PRODUCTION!)
JWT_SECRET_KEY=your-secret-key-change-in-production

# AI - OpenRouter (ONLY key needed for ALL AI features)
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=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

# SMTP — Ethereal (test/catch-all) or real provider in production
# Ethereal credentials: messages are caught at https://ethereal.email/messages
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USERNAME=shyann.homenick33@ethereal.email
SMTP_PASSWORD=zu9jj8r99791R6fhUZ
SMTP_USE_TLS=true
MAIL_FROM_EMAIL=shyann.homenick33@ethereal.email
MAIL_FROM_NAME=ChampMail Test

# IMAP — Ethereal (same account)
IMAP_HOST=imap.ethereal.email
IMAP_PORT=993
IMAP_USERNAME=shyann.homenick33@ethereal.email
IMAP_PASSWORD=zu9jj8r99791R6fhUZ
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX

# PUBLIC URL (set by `champmail tunnel start` or your deployment URL)
PUBLIC_API_URL=http://localhost:8000

# CORS
FRONTEND_URL=http://localhost:3000
